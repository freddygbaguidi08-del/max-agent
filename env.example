# ================================================================
# MAX AGENT — Variables d'environnement
# 1. Copier ce fichier : cp .env.example .env.local
# 2. Remplir chaque valeur
# 3. Sur Vercel : ajouter ces variables dans Settings > Environment Variables
# ================================================================

# --- Anthropic (OBLIGATOIRE) ---
# Obtenir sur : https://console.anthropic.com/settings/keys
GROQ_API_KEY=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

# --- Google Ads API (pour mode production) ---
# Guide complet : https://developers.google.com/google-ads/api/docs/first-call/overview
# Laisser vide pour utiliser le mode DEMO avec données simulées
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=

# --- Google Merchant Center (pour mode production) ---
MERCHANT_CENTER_ID=

# --- WooCommerce (pour mode production) ---
WOOCOMMERCE_URL=
WOOCOMMERCE_CONSUMER_KEY=
WOOCOMMERCE_CONSUMER_SECRET=

# --- Sécurité dashboard ---s
# Mot de passe pour accéder au dashboard (min 8 caractères)
DASHBOARD_PASSWORD=changez-moi-en-production

# --- Garde-fous agent ---
MAX_DAILY_BUDGET_EUR=200
MIN_ROAS_THRESHOLD=1.5
REQUIRE_APPROVAL=true

# --- Mode ---
# "demo" = données simulées réalistes (par défaut si APIs vides)
# "production" = vraies APIs Google
AGENT_MODE=demo
